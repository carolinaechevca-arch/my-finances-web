# Copia este archivo a ".env" y completa los valores.
# El Client ID de Google NO es secreto (se usa en el navegador), pero de
# todas formas se maneja por variable de entorno para no hardcodearlo.
# Quién puede iniciar sesión se controla desde Google Cloud Console
# (Google Auth Platform → Público → Usuarios de prueba), no desde la app.
VITE_GOOGLE_CLIENT_ID=

# Se completa solo la primera vez, después de que la app crea el
# spreadsheet automáticamente y te muestra su ID en pantalla.
VITE_SPREADSHEET_ID=
